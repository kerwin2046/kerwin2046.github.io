# Copy to .env.local and fill in. See README for dev/prod env files.

# App environment (development | production). Next 会按 NODE_ENV 自动加载 .env.development / .env.production
NEXT_PUBLIC_APP_ENV=

# Optional: Chat（对话 / 向博客提问）。优先 DeepSeek，未配置则用 OpenAI；封面生成脚本也用 OPENAI_API_KEY
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=
# Optional: 若需要 API 或站点 URL
# NEXT_PUBLIC_SITE_URL=
